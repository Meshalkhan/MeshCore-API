{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build --workspace frontend",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/[...all].ts": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}